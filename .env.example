# GeoHypothesis Explorer Environment Variables
# Copy this file to .env and fill in your values

# Server-side Gemini API Key (required for free analysis feature)
# This key is used when users don't provide their own API key
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Additional API keys for server-side features
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# XAI_API_KEY=your_grok_key_here
