# GeoHypothesis Explorer Environment Variables
# Copy this file to .env and fill in your values

# Note: API keys are entered by users in the browser and sent directly
# to AI providers. No server-side API keys are required for the application.

# Optional: For future server-side features
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GOOGLE_AI_API_KEY=your_gemini_key_here
# XAI_API_KEY=your_grok_key_here
